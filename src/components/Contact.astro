<section id="kontakt" class="py-16 md:py-24 bg-light">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Skontaktuj się z nami</h2>
      <p class="text-lg text-dark/60 max-w-xl mx-auto">
        Masz pytania? Zadzwoń — chętnie doradzimy i pomożemy wybrać idealną wycieczkę.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <!-- Form -->
      <form id="contact-form" class="bg-white rounded-2xl p-6 md:p-8 shadow-sm">
        <div class="space-y-5">
          <div>
            <label for="name" class="block text-base font-semibold text-dark mb-2">Imię</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-body focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Twoje imię"
            />
          </div>
          <div>
            <label for="phone" class="block text-base font-semibold text-dark mb-2">Telefon</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-body focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Twój numer telefonu"
            />
          </div>
          <div>
            <label for="email" class="block text-base font-semibold text-dark mb-2">Email <span class="text-dark/40 font-normal">(opcjonalnie)</span></label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-body focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              placeholder="Twój email"
            />
          </div>
          <div>
            <label for="message" class="block text-base font-semibold text-dark mb-2">Wiadomość</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl text-body focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent resize-y"
              placeholder="Napisz wiadomość..."
            ></textarea>
          </div>
          <button
            type="submit"
            id="contact-submit"
            class="w-full bg-accent text-white font-bold text-body py-4 rounded-xl hover:bg-accent/90 transition-colors min-h-touch"
          >
            Wyślij wiadomość
          </button>
          <div id="contact-status" class="hidden text-center py-3 rounded-xl font-semibold"></div>
        </div>
      </form>

      <script>
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const btn = document.getElementById('contact-submit') as HTMLButtonElement;
        const status = document.getElementById('contact-status') as HTMLDivElement;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          btn.disabled = true;
          btn.textContent = 'Wysyłanie...';
          status.classList.add('hidden');

          const data = {
            name: (form.querySelector('#name') as HTMLInputElement).value,
            phone: (form.querySelector('#phone') as HTMLInputElement).value,
            email: (form.querySelector('#email') as HTMLInputElement).value,
            message: (form.querySelector('#message') as HTMLTextAreaElement).value,
          };

          try {
            const res = await fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });

            if (res.ok) {
              status.textContent = 'Wiadomość wysłana! Odezwiemy się wkrótce.';
              status.className = 'text-center py-3 rounded-xl font-semibold bg-green-100 text-green-800';
              form.reset();
            } else {
              throw new Error();
            }
          } catch {
            status.textContent = 'Błąd wysyłania. Spróbuj ponownie lub zadzwoń.';
            status.className = 'text-center py-3 rounded-xl font-semibold bg-red-100 text-red-800';
          } finally {
            btn.disabled = false;
            btn.textContent = 'Wyślij wiadomość';
          }
        });
      </script>

      <!-- Contact info -->
      <div class="flex flex-col gap-6">
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm">
          <h3 class="text-xl font-bold text-dark mb-4">Biuro Podróży TravelPL</h3>
          <ul class="space-y-4 text-dark/70">
            <li class="flex items-start gap-3">
              <svg class="text-primary shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>ul. Wrocławska 7, Wieruszów</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-accent shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <div>
                <a href="tel:+48793705063" class="block hover:text-accent transition-colors font-semibold">793 705 063</a>
                <a href="tel:+48883005008" class="block hover:text-accent transition-colors font-semibold">883 005 008</a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-accent shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <a href="mailto:kontakt@travelpl-wieruszow.pl" class="hover:text-accent transition-colors font-semibold">kontakt@travelpl-wieruszow.pl</a>
            </li>
            <li class="flex items-start gap-3">
              <svg class="text-primary shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <p class="font-semibold text-dark">Godziny otwarcia biura:</p>
                <p>Poniedziałek: 16:00 – 19:00</p>
                <p>Środa: 11:00 – 13:00</p>
              </div>
            </li>
          </ul>
        </div>

        <a
          href="https://www.facebook.com/transport.autokarow/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-3 bg-[#1877F2] text-white font-bold text-body py-4 px-6 rounded-xl hover:bg-[#1877F2]/90 transition-colors min-h-touch"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Odwiedź nas na Facebooku
        </a>

        <div class="bg-primary text-white rounded-2xl p-6 md:p-8 text-center">
          <p class="text-xl font-bold mb-2">Wolisz zadzwonić?</p>
          <p class="text-white/80 mb-4">To najszybszy sposób na rezerwację!</p>
          <a
            href="tel:+48793705063"
            class="inline-flex items-center justify-center gap-2 bg-white text-primary font-bold text-body px-8 py-4 rounded-xl hover:bg-white/90 transition-colors min-h-touch"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Zadzwoń: 793 705 063
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
