---
const steps = [
  {
    number: '1',
    title: 'Wybierz wycieczkę',
    text: 'Przejrzyj naszą ofertę i wybierz termin oraz destynację, która Ci odpowiada.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
  },
  {
    number: '2',
    title: 'Zadzwoń lub odwiedź biuro',
    text: 'Skontaktuj się z nami telefonicznie lub przyjdź do biura — potwierdzimy dostępność i zarezerwujemy miejsce.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>',
  },
  {
    number: '3',
    title: 'Pakuj walizkę!',
    text: 'Reszta po naszej stronie — przejazd, hotel, wyżywienie, ubezpieczenie i atrakcje.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>',
  },
];
---

<section class="py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Rezerwacja w 3 krokach</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
      {steps.map((step) => (
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-4 bg-primary/10 rounded-2xl flex items-center justify-center text-primary" set:html={step.icon} />
          <div class="w-10 h-10 mx-auto mb-3 bg-accent text-white rounded-full flex items-center justify-center font-bold text-lg">
            {step.number}
          </div>
          <h3 class="text-xl font-bold text-dark mb-2">{step.title}</h3>
          <p class="text-dark/70 leading-relaxed">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
