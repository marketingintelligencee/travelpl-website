---
import { trips } from '../data/trips';
import TripCard from './TripCard.astro';

const featured = trips.filter((t) => t.featured);
---

<section class="py-16 md:py-24 bg-light">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Najbliższe wyjazdy</h2>
      <p class="text-lg text-dark/60 max-w-xl mx-auto">
        Sprawdź najbliższe terminy — liczba miejsc ograniczona!
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {featured.map((trip, i) => (
        <div class="reveal" style={`animation-delay: ${i * 150}ms`}>
          <TripCard trip={trip} />
        </div>
      ))}
    </div>
  </div>
</section>
