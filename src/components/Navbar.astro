---
const navItems = [
  { label: 'Oferta', href: '/#oferta' },
  { label: 'Wycieczki szkolne', href: '/wycieczki-szkolne' },
  { label: 'O nas', href: '/o-nas' },
  { label: 'Aplikacja', href: '/aplikacja' },
  { label: 'Kontakt', href: '/#kontakt' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-sm transition-shadow" id="navbar">
  <nav class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href="/" class="text-2xl font-bold text-primary tracking-tight">
      Travel<span class="text-accent">PL</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-dark hover:text-primary font-medium transition-colors text-body"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="tel:+48793705063"
          class="inline-flex items-center gap-2 bg-accent text-white font-bold px-5 py-2.5 rounded-lg hover:bg-accent/90 transition-colors text-body"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          793 705 063
        </a>
      </li>
    </ul>

    <!-- Mobile: phone + hamburger -->
    <div class="flex items-center gap-3 lg:hidden">
      <a
        href="tel:+48793705063"
        class="text-accent font-bold text-body"
      >
        793 705 063
      </a>
      <button
        id="menu-toggle"
        class="p-2 rounded-lg hover:bg-light transition-colors"
        aria-label="Otwórz menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="menu-icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100">
    <ul class="flex flex-col py-4 px-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block py-3 px-4 text-dark hover:text-primary hover:bg-light rounded-lg font-medium text-body transition-colors"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
