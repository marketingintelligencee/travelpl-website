<section class="relative w-full h-screen min-h-[600px] max-h-[1000px] overflow-hidden bg-dark">

  <!-- Video Background -->
  <video
    id="hero-video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500"
  >
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Dark Overlay — gradient for text readability -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex items-center">
    <div class="max-w-7xl mx-auto px-4 w-full">

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white mb-4 max-w-3xl drop-shadow-lg">
        Wycieczki autokarowe z Wieruszowa — wsiadasz i jedziesz!
      </h1>

      <p class="text-lg md:text-xl leading-relaxed text-white/85 mb-8 max-w-2xl drop-shadow-md">
        Od lat organizujemy wczasy nad morzem, w górach i za granicą. Hotel, wyżywienie i ubezpieczenie — wszystko w cenie. Wystarczy spakować walizkę!
      </p>

      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a
          href="#oferta"
          class="inline-flex items-center justify-center bg-accent text-white font-bold text-body px-8 py-4 rounded-xl hover:bg-accent/90 hover:scale-105 transition-all min-h-touch w-full sm:w-auto shadow-lg"
        >
          Zobacz wycieczki i ceny
        </a>
        <a
          href="tel:+48793705063"
          class="inline-flex items-center justify-center gap-2 bg-white/15 backdrop-blur-sm text-white font-bold text-body px-8 py-4 rounded-xl hover:bg-white/25 transition-all min-h-touch w-full sm:w-auto border border-white/30"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Zadzwoń — zarezerwuj miejsce
          <span class="text-sm font-normal opacity-80">793 705 063</span>
        </a>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 scroll-indicator">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-60"><polyline points="6 9 12 15 18 9"/></svg>
  </div>

  <!-- Subtle bottom fade into next section -->
  <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>

</section>

<!-- Trust bar -->
<div class="bg-primary text-white py-4">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-8 text-sm md:text-base">
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Ubezpieczenie NNW w cenie
      </span>
      <span class="hidden sm:block text-white/40">|</span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Wyjazd z Wieruszowa
      </span>
      <span class="hidden sm:block text-white/40">|</span>
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        Nr lic. [DO UZUPEŁNIENIA]
      </span>
    </div>
  </div>
</div>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement;
  if (video) {
    const show = () => { video.style.opacity = '1'; };
    if (video.readyState >= 2) {
      show();
    } else {
      video.addEventListener('canplay', show, { once: true });
    }
  }
</script>
