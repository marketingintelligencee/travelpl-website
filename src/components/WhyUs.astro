---
const reasons = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
    title: 'Wszystko w cenie — zero niespodzianek',
    text: 'Przejazd, hotel, wyżywienie, ubezpieczenie i atrakcje — płacisz raz i nie musisz się martwić o nic więcej.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
    title: 'Wyjazd z Wieruszowa',
    text: 'Nie musisz jechać do dużego miasta na zbiórkę. Wsiadasz w autokar u siebie — wygodnie i bez stresu.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>',
    title: 'Zwiedzanie z przewodnikiem',
    text: 'Każda wycieczka to nie tylko odpoczynek, ale też odkrywanie nowych miejsc z profesjonalnym przewodnikiem.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
    title: 'Integracja i dobra zabawa',
    text: 'Biesiady przy ognisku, disco z DJ-em, wieczorki taneczne — u nas nie ma nudy!',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>',
    title: 'Od morza po góry',
    text: '12 wycieczek w sezonie 2026: Bałtyk, Beskidy, Bieszczady, Podlasie, a nawet Budapeszt.',
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
    title: 'Przystępne ceny',
    text: 'Od 1 250 zł za 4 dni do 2 300 zł za 9 dni — pełne wakacje z wyżywieniem i atrakcjami.',
  },
];
---

<section class="py-16 md:py-24 bg-light">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-10 md:mb-14">
      <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Dlaczego warto z nami jechać?</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {reasons.map((reason) => (
        <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="text-primary mb-4" set:html={reason.icon} />
          <h3 class="text-xl font-bold text-dark mb-2">{reason.title}</h3>
          <p class="text-dark/70 leading-relaxed">{reason.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
