---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <div class="max-w-7xl mx-auto px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-2xl font-bold">
          Travel<span class="text-accent">PL</span>
        </a>
        <p class="mt-3 text-gray-300 text-body leading-relaxed">
          Wygodne wycieczki autokarowe z Wieruszowa — morze, góry, przygoda. Wszystko w cenie.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xl font-bold mb-4">Kontakt</h3>
        <ul class="space-y-2 text-gray-300">
          <li>
            <a href="tel:+48793705063" class="hover:text-accent transition-colors">
              Tel. 793 705 063
            </a>
          </li>
          <li>
            <a href="tel:+48883005008" class="hover:text-accent transition-colors">
              Tel. 883 005 008
            </a>
          </li>
          <li>ul. Wrocławska 7, Wieruszów</li>
          <li>Pn 16:00–19:00, Śr 11:00–13:00</li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xl font-bold mb-4">Nawigacja</h3>
        <ul class="space-y-2 text-gray-300">
          <li><a href="/#oferta" class="hover:text-accent transition-colors">Oferta 2026</a></li>
          <li><a href="/o-nas" class="hover:text-accent transition-colors">O nas</a></li>
          <li><a href="/aplikacja" class="hover:text-accent transition-colors">Aplikacja</a></li>
          <li><a href="/#kontakt" class="hover:text-accent transition-colors">Kontakt</a></li>
          <li>
            <a
              href="https://www.facebook.com/transport.autokarow/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent transition-colors inline-flex items-center gap-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 mt-10 pt-6 text-center text-gray-400 text-sm">
      <p>© {currentYear} Biuro Podróży TravelPL. Wszelkie prawa zastrzeżone.</p>
    </div>
  </div>
</footer>
