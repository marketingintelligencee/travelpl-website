---
import type { Trip } from '../data/trips';

interface Props {
  trip: Trip;
}

const { trip } = Astro.props;

const formattedPrice = new Intl.NumberFormat('pl-PL').format(trip.price);

const regionColors: Record<string, string> = {
  morze: 'bg-primary/10 text-primary',
  gory: 'bg-success/10 text-success',
  miasto: 'bg-accent/10 text-accent',
  zagranica: 'bg-amber-100 text-amber-700',
};

const regionLabels: Record<string, string> = {
  morze: 'Morze',
  gory: 'Góry',
  miasto: 'Miasto',
  zagranica: 'Zagranica',
};

const typeLabel = trip.type === 'wczasy' ? 'Wczasy' : 'Wycieczka';
---

<article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
  <!-- Image -->
  <div class="relative h-48 md:h-56 bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center overflow-hidden">
    {trip.image ? (
      <img
        src={trip.image}
        alt={trip.fullName}
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <span class="text-primary/40 text-3xl font-bold">{trip.name}</span>
    )}
    <span class={`absolute top-3 left-3 text-sm font-medium px-3 py-1 rounded-full ${regionColors[trip.region]}`}>
      {regionLabels[trip.region]}
    </span>
    {(trip.urgencyBadge || trip.badge) && (
      <span class={`absolute top-3 right-3 text-white text-sm font-bold px-3 py-1 rounded-full ${trip.urgencyBadge ? 'bg-red-600 animate-pulse' : 'bg-accent'}`}>
        {trip.urgencyBadge || trip.badge}
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 md:p-6 flex flex-col flex-1">
    <h3 class="text-xl font-bold text-dark mb-1">{trip.fullName}</h3>
    <div class="flex flex-wrap gap-3 text-sm text-dark/60 mb-2">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {trip.dates}
      </span>
      <span>{trip.duration}</span>
      <span class="text-dark/50">·</span>
      <span>{typeLabel}</span>
      {trip.beachDistance && (
        <span class="text-primary font-medium">{trip.beachDistance}</span>
      )}
    </div>
    <p class="text-dark/70 text-base leading-relaxed mb-4 flex-1">{trip.shortDescription}</p>
    <div class="flex items-end justify-between mt-auto pt-3 border-t border-gray-100">
      <div>
        <span class="text-sm text-dark/50">od</span>
        <span class="text-2xl font-bold text-primary ml-1">{formattedPrice} zł</span>
        <span class="text-sm text-dark/50">/os</span>
      </div>
      <a
        href={`/wycieczka/${trip.slug}`}
        class="inline-flex items-center gap-1 bg-primary text-white font-bold px-5 py-2.5 rounded-lg hover:bg-primary/90 transition-colors text-base"
      >
        Więcej
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <a
      href="tel:+48793705063"
      class="mt-3 inline-flex items-center justify-center gap-2 text-accent font-bold text-base py-2.5 rounded-lg hover:bg-accent/5 transition-colors min-h-touch w-full border border-accent/30"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Zadzwoń i zarezerwuj
    </a>
  </div>
</article>
