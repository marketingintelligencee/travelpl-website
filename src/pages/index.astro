---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeaturedTrips from '../components/FeaturedTrips.astro';
import Testimonials from '../components/Testimonials.astro';
import TripGrid from '../components/TripGrid.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <Hero />
  <FeaturedTrips />
  <Testimonials />
  <TripGrid />

  <!-- Jak podróżujemy -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10 md:mb-14">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Jak podróżujemy?</h2>
        <p class="text-lg text-dark/60 max-w-xl mx-auto">Komfort i bezpieczeństwo przez całą drogę.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8 max-w-3xl mx-auto">
        <div class="text-center p-6 bg-light rounded-2xl">
          <div class="text-primary mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto"><path d="M8 2v4"/><path d="M16 2v4"/><path d="M21 12.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7.5"/><path d="m15.5 17.5 2 2 4-4"/></svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-1">Klimatyzacja</h3>
          <p class="text-dark/60 text-base">Przyjemna temperatura niezależnie od pogody</p>
        </div>
        <div class="text-center p-6 bg-light rounded-2xl">
          <div class="text-primary mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto"><path d="M12 12h.01"/><path d="M16 6V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-1">Wygodne fotele</h3>
          <p class="text-dark/60 text-base">Rozkładane siedzenia z dużą ilością miejsca na nogi</p>
        </div>
        <div class="text-center p-6 bg-light rounded-2xl">
          <div class="text-primary mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-1">Przerwy w trasie</h3>
          <p class="text-dark/60 text-base">Regularne postoje na kawę i odpoczynek</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banner szkolny -->
  <section class="py-8 bg-primary">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-white text-lg md:text-xl font-bold mb-3">
        Organizujesz wycieczkę szkolną?
      </p>
      <a
        href="/wycieczki-szkolne"
        class="inline-flex items-center gap-2 bg-white text-primary font-bold px-8 py-3 rounded-xl hover:bg-white/90 transition-colors min-h-touch"
      >
        Zobacz naszą ofertę dla szkół
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </section>

  <Contact />
</Layout>
