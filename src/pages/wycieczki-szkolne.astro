---
import Layout from '../layouts/Layout.astro';
import Contact from '../components/Contact.astro';

const schoolTrips = [
  {
    title: 'Radzionków + Kopalnia Srebra w Tarnowskich Górach',
    region: 'Śląsk',
    description: 'Muzeum Chleba, Szkoły i Ciekawostek — warsztaty wypieku chleba, lekcja w dawnej klasie, pisanie rysikiem na tabliczkach. Kopalnia Zabytkowa Rud Srebronośnych — podziemny labirynt z rejsem łodziami przy lampach karbidowych.',
    highlights: ['Warsztaty piekarskie', 'Lekcja w dawnej klasie', 'Rejs łodziami w kopalni', 'Spotkanie ze Skarbnikiem'],
  },
  {
    title: 'Łódź — Orientarium + Hopa Lupa',
    region: 'Łódzkie',
    description: 'Orientarium ZOO Łódź — flora i fauna Azji Południowo-Wschodniej, podwodny tunel z rekinami i płaszczkami. Hopa Lupa Park — park trampolin łączący aktywność fizyczną, integrację i zabawę.',
    highlights: ['Podwodny tunel', '180 gatunków zwierząt', 'Park trampolin', 'Integracja i ruch'],
  },
  {
    title: 'Łódź — EC1 + Manufaktura + Muzeum Włókiennictwa',
    region: 'Łódzkie',
    description: 'EC1 — interaktywne muzeum energii w zrewitalizowanej elektrowni. Muzeum Fabryki w Manufakturze — historia „króla bawełny" Izraela Poznańskiego. Centralne Muzeum Włókiennictwa + warsztaty kreatywne.',
    highlights: ['Interaktywne eksponaty', 'Zabytkowe maszyny', 'Warsztaty kreatywne', 'Historia przemysłu'],
  },
  {
    title: 'Wrocław — Hydropolis + Gokarty',
    region: 'Dolny Śląsk',
    description: 'Hydropolis — interaktywna wystawa poświęcona wodzie z multimedialnymi eksponatami. Pitlane — nowoczesny tor gokartowy dostosowany do dzieci, łączący wyścigi z bezpieczeństwem.',
    highlights: ['Multimedialna wystawa o wodzie', 'Tor gokartowy dla dzieci', 'Nauka + zabawa', 'Bezpieczna rywalizacja'],
  },
  {
    title: 'Warszawa — Pełna przygód stolica',
    region: 'Mazowieckie',
    description: 'Taras PKiN z panoramą Warszawy, Łazienki Królewskie, Stadion Narodowy (szatnie, loża VIP), Stare Miasto z przewodnikiem, Centrum Nauki Kopernik, Muzeum Iluzji, Fabryka Czekolady E.Wedel, Zamek Królewski.',
    highlights: ['Centrum Nauki Kopernik', 'Stadion Narodowy', 'Fabryka Czekolady Wedel', 'Zamek Królewski'],
  },
  {
    title: 'Toruń — Miasto Kopernika',
    region: 'Kujawsko-pomorskie',
    description: 'Zwiedzanie Starego Miasta z przewodnikiem — Piernikowa Aleja Gwiazd, Krzywa Wieża, Dwór Artusa. Muzeum Toruńskiego Piernika, Planetarium oraz warsztaty piernikarskie z własnoręcznym wypiekiem.',
    highlights: ['Warsztaty piernikarskie', 'Planetarium', 'Muzeum Piernika', 'Fort IV ze spacer z pochodniami'],
  },
  {
    title: 'Kraków + Wieliczka',
    region: 'Małopolska',
    description: 'Wzgórze Wawelskie — Katedra, Dzwon Zygmunta, groby królewskie. Droga Królewska, Stare Miasto, Muzeum Obwarzanka z warsztatami. Spacer na Kopiec Kraka, Kazimierz i Kopalnia Soli w Wieliczce.',
    highlights: ['Kopalnia Soli w Wieliczce', 'Wawel i Katedra', 'Warsztaty obwarzankowe', 'Krakowski Kazimierz'],
  },
  {
    title: 'Trójmiasto — Gdańsk, Gdynia, Sopot',
    region: 'Pomorskie',
    description: 'ORP Błyskawica, klif w Orłowie, Muzeum Emigracji, Europejskie Centrum Solidarności, Stocznia Gdańska, gra miejska po Gdańsku, Centrum Nauki Experyment, Molo w Sopocie.',
    highlights: ['Centrum Nauki Experyment', 'ECS Solidarność', 'Gra miejska Gdańsk', 'Molo w Sopocie'],
  },
  {
    title: 'Świętokrzyskie — Legendy i przyroda',
    region: 'Świętokrzyskie',
    description: 'Park Legend Świętokrzyskich z VR, Łysa Góra lub Łysica, Harmonia — Świętokrzyska Zagroda Kultury, Osada Średniowieczna z warsztatami garncarskimi, Zamek w Chęcinach, Jaskinia Raj, Centrum Nauki Leonardo Da Vinci.',
    highlights: ['Park Legend z VR', 'Jaskinia Raj', 'Warsztaty garncarskie', 'Zamek w Chęcinach'],
  },
  {
    title: 'Kłodzko — Twierdze i jaskinie',
    region: 'Dolny Śląsk',
    description: 'Kłodzko z Gotyckim Mostem, Twierdza Kłodzko, Kopalnia Złota w Złotym Stoku z Laboratorium Alchemika, Jaskinia Niedźwiedzia w Kletnie, Góra Borówkowa z wieżą widokową. Opcjonalnie: spływ pontonami, Szczeliniec Wielki, Błędne Skały.',
    highlights: ['Kopalnia Złota', 'Jaskinia Niedźwiedzia', 'Twierdza Kłodzko', 'Spływ pontonami'],
  },
  {
    title: 'Kórnik — Puszczkowo — Rogalin',
    region: 'Wielkopolska',
    description: 'Rezydencja Magnacka Działyńskich w Kórniku, Muzeum Arkadego Fiedlera w Puszczykowie z repliką Santa Marii, Pałac w Rogalinie z legendarnymi dębami rogalińskimi.',
    highlights: ['Pałac w Kórniku', 'Replika Santa Marii', 'Dęby rogalińskie', 'Muzeum Fiedlera'],
  },
  {
    title: 'Twierdza Srebrna Góra',
    region: 'Dolny Śląsk',
    description: 'Jedyna twierdza górska w Polsce i największa budowla forteczna w Europie — Pomnik Historii. Zwiedzanie z przewodnikiem bastionów, Muzeum, możliwość zwiedzania fortów z fabułą i ogniska z kiełbaskami.',
    highlights: ['Największa twierdza górska w Europie', 'Pomnik Historii', 'Zwiedzanie z fabułą', 'Ognisko z kiełbaskami'],
  },
];
---

<Layout title="Wycieczki szkolne — TravelPL" description="Organizujemy wycieczki szkolne dla dzieci i młodzieży. Autokar, ubezpieczenie, piloci — wszystko w pakiecie. Skontaktuj się po indywidualną wycenę!">

  <!-- Hero -->
  <section class="relative py-20 md:py-28 bg-gradient-to-br from-primary/20 to-accent/10">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="inline-flex items-center bg-accent text-white text-sm font-bold px-4 py-1.5 rounded-full mb-6">
        Dla szkół i grup zorganizowanych
      </span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-dark mb-5">
        Wycieczki szkolne
      </h1>
      <p class="text-lg md:text-xl text-dark/70 max-w-2xl mx-auto mb-8 leading-relaxed">
        Organizujemy wycieczki szkolne dla dzieci i młodzieży w całej Polsce. Przejazd autokarem, ubezpieczenie, rezerwacje biletów, opieka pilota — wszystko w pakiecie. Każda wycieczka wyceniana indywidualnie.
      </p>
      <a
        href="#kontakt"
        class="inline-flex items-center justify-center bg-accent text-white font-bold text-body px-8 py-4 rounded-xl hover:bg-accent/90 transition-colors min-h-touch shadow-lg"
      >
        Zapytaj o wycenę
      </a>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-12 md:py-16 border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-dark mb-6 text-center">Co zawiera każda wycieczka?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Przejazd autokarem lub busem',
          'Rezerwacja biletów wstępu',
          'Opieka pilota / przewodnika',
          'Ubezpieczenie NNW',
          'Opłaty drogowe i parkingowe',
          'Podatek VAT i opłaty TFG',
        ].map((item) => (
          <div class="flex items-center gap-3 bg-light rounded-xl px-4 py-3">
            <svg class="text-success shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span class="text-dark/80 font-medium">{item}</span>
          </div>
        ))}
      </div>
      <p class="text-center text-dark/50 mt-6 text-base">
        Cena zależy od: miejsca wyjazdu, liczebności grupy i terminu.
      </p>
    </div>
  </section>

  <!-- Example trips -->
  <section class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-10 md:mb-14">
        <h2 class="text-2xl md:text-3xl font-bold text-dark mb-3">Przykładowe wycieczki</h2>
        <p class="text-lg text-dark/60 max-w-2xl mx-auto">
          To tylko wybrane propozycje — jesteśmy otwarci na Wasze sugestie. Program ma charakter ramowy i może być modyfikowany.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {schoolTrips.map((trip) => (
          <article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-shadow flex flex-col">
            <div class="p-5 md:p-6 flex flex-col flex-1">
              <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full mb-3 self-start">
                {trip.region}
              </span>
              <h3 class="text-lg font-bold text-dark mb-2">{trip.title}</h3>
              <p class="text-dark/70 text-base leading-relaxed mb-4 flex-1">{trip.description}</p>
              <div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-gray-100">
                {trip.highlights.map((h) => (
                  <span class="bg-accent/10 text-accent text-xs font-medium px-2.5 py-1 rounded-full">{h}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 md:py-16 bg-primary text-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Nie znalazłeś odpowiedniej wycieczki?</h2>
      <p class="text-white/80 text-lg mb-6">
        Bez problemu! Przygotujemy indywidualną ofertę dostosowaną do potrzeb Twojej szkoły. Wystarczy, że napiszesz lub zadzwonisz.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center bg-white text-primary font-bold text-body px-8 py-4 rounded-xl hover:bg-white/90 transition-colors min-h-touch"
        >
          Napisz do nas
        </a>
        <a
          href="tel:+48793705063"
          class="inline-flex items-center justify-center gap-2 bg-white/15 text-white font-bold text-body px-8 py-4 rounded-xl hover:bg-white/25 transition-colors min-h-touch border border-white/30"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Zadzwoń: 793 705 063
        </a>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <Contact />

</Layout>
